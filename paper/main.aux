\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Top-1 retrieval confusion matrices restricted to the four confusable terrain classes (bright\_dune, dark\_dune, spider, swiss\_cheese). Lower off-diagonal mass indicates fewer cross-class retrieval errors. ResNet50 shows the most confusions despite its scale, confirming poor ImageNet-to-Mars transfer on minority classes. \textsc  {QTerrainSim}{}'s interleaved encoding yields the fewest confusions, consistent with the macro-MAP@10 rankings in Table~\ref {tab:main}.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:confusion}{{3}{5}{Top-1 retrieval confusion matrices restricted to the four confusable terrain classes (bright\_dune, dark\_dune, spider, swiss\_cheese). Lower off-diagonal mass indicates fewer cross-class retrieval errors. ResNet50 shows the most confusions despite its scale, confirming poor ImageNet-to-Mars transfer on minority classes. \qts {}'s interleaved encoding yields the fewest confusions, consistent with the macro-MAP@10 rankings in Table~\ref {tab:main}}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Mean absolute PQC parameter gradient over 50 training epochs. Dashed red line: barren plateau detection threshold ($10^{-5}$). Both models remain above the threshold throughout at $N{=}8$, consistent with the Cerezo et~al.\ prediction that local Pauli-$Z$ measurements reduce gradient suppression relative to global observables; scaling verification across multiple $N$ is deferred to future work. The COBYLA fallback was never triggered in any experiment.}}{5}{figure.4}\protected@file@percent }
\newlabel{fig:gradnorm}{{4}{5}{Mean absolute PQC parameter gradient over 50 training epochs. Dashed red line: barren plateau detection threshold ($10^{-5}$). Both models remain above the threshold throughout at $N{=}8$, consistent with the Cerezo et~al.\ prediction that local Pauli-$\PauliZ $ measurements reduce gradient suppression relative to global observables; scaling verification across multiple $N$ is deferred to future work. The COBYLA fallback was never triggered in any experiment}{figure.4}{}}
