\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Entangled-pair quantum circuit (shown for $N=4$ for clarity). Each wire~$i$ first receives $R_X(\pi e_a^{(i)})$ (blue), encoding component~$i$ of the first embedding via rotation around the $X$-axis, then $R_Y(\pi e_b^{(i)})$ (orange), encoding component~$i$ of the second embedding around the orthogonal $Y$-axis. Because $[R_X,R_Y]\neq  0$, the resulting per-qubit state is a nonlinear joint function of both inputs. \emph  {SEL}: StronglyEntanglingLayers~\cite  {bergholm2018pennylane}, depth $L$, with $3NL$ variational parameters $\bm  {\theta }$; at $N{=}8, L{=}2$ this is 48 parameters. Each wire is measured locally with Pauli-$Z$, yielding $\langle Z_i\rangle \in [-1,1]$, which is passed to a trainable linear layer and sigmoid to produce the similarity score $s\in (0,1)$. }}{3}{figure.2}\protected@file@percent }
\newlabel{fig:circuit}{{2}{3}{Entangled-pair quantum circuit (shown for $N=4$ for clarity). Each wire~$i$ first receives $\RX (\pi e_a^{(i)})$ (blue), encoding component~$i$ of the first embedding via rotation around the $X$-axis, then $\RY (\pi e_b^{(i)})$ (orange), encoding component~$i$ of the second embedding around the orthogonal $Y$-axis. Because $[\RX ,\RY ]\neq 0$, the resulting per-qubit state is a nonlinear joint function of both inputs. \emph {SEL}: StronglyEntanglingLayers~\cite {bergholm2018pennylane}, depth $L$, with $3NL$ variational parameters $\bm {\theta }$; at $N{=}8, L{=}2$ this is 48 parameters. Each wire is measured locally with Pauli-$\PauliZ $, yielding $\langle Z_i\rangle \in [-1,1]$, which is passed to a trainable linear layer and sigmoid to produce the similarity score $s\in (0,1)$}{figure.2}{}}
